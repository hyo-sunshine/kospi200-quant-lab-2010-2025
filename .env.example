# 이 파일을 .env 로 복사한 뒤 실제 값을 채우세요. (.env 는 git에 올라가지 않음)
#   cp .env.example .env

# 한국은행 ECOS Open API — 매크로(환율·기준금리·국고3년) 일별 갱신
# 발급: https://ecos.bok.or.kr → 회원가입 → 마이페이지 → 인증키 신청 (무료, 즉시)
ECOS_API_KEY=

# 금융감독원 DART Open API — 분기 재무제표 (현재 파이프라인은 ffill, 추후 사용)
# 발급: https://opendart.fss.or.kr → 인증키 신청/관리 (무료, 즉시)
DART_API_KEY=

# KRX 정보데이터시스템 로그인 계정 — 수급(외국인/기관/개인)·공매도 일별 수집
# 가입: https://data.krx.co.kr → 회원가입 (무료)
#   * 네이버 등 SNS로 가입한 경우: 마이페이지 → 정보수정에서 비밀번호를
#     신규 설정해야 아이디/비밀번호 로그인(pykrx)이 가능
KRX_ID=
KRX_PW=
